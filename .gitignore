# ═══════════════════════════════════════════════════════
# MAVEN BUILD OUTPUT
# The target/ folder contains compiled .class files and
# the generated JAR. These are huge (50-100MB) and can
# always be regenerated by running mvn package.
# Never commit compiled output — only commit source code.
# ═══════════════════════════════════════════════════════
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ═══════════════════════════════════════════════════════
# !! CRITICAL — YOUR LOCAL DATABASE PASSWORD !!
# application.properties contains:
#   spring.datasource.password=garage123
# This must NEVER go to GitHub — anyone could see it.
# application-prod.properties is SAFE to commit because
# it uses ${VARIABLE_NAME} placeholders, not real passwords.
# ═══════════════════════════════════════════════════════
src/main/resources/application.properties

# ═══════════════════════════════════════════════════════
# ECLIPSE IDE FILES
# These are Eclipse workspace settings — personal to your
# machine. Other developers use different IDEs and don't
# need these. They also change constantly and create noise
# in git history.
# ═══════════════════════════════════════════════════════
.classpath
.project
.settings/
.factorypath

# ═══════════════════════════════════════════════════════
# INTELLIJ IDEA FILES (in case anyone else uses IntelliJ)
# ═══════════════════════════════════════════════════════
.idea/
*.iml
*.iws
*.ipr

# ═══════════════════════════════════════════════════════
# WINDOWS / MAC OS FILES
# .DS_Store = Mac Finder metadata
# Thumbs.db = Windows thumbnail cache
# ═══════════════════════════════════════════════════════
.DS_Store
Thumbs.db
desktop.ini

# ═══════════════════════════════════════════════════════
# LOGS
# ═══════════════════════════════════════════════════════
*.log
logs/

# ═══════════════════════════════════════════════════════
# ENVIRONMENT / SECRET FILES
# Any file ending in .env typically contains secrets.
# ═══════════════════════════════════════════════════════
.env
*.env